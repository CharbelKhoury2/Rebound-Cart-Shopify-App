# Shopify App Configuration
# Copy this file to .env and update with your actual values

# Your Shopify App URL (where your Remix app is running)
VITE_SHOPIFY_APP_URL=https://institutes-rear-modular-expected.trycloudflare.com

# API Key for authentication (generate a secure key)
VITE_API_KEY=your-secure-api-key-here

# WebSocket URL for real-time updates
VITE_WS_URL=wss://institutes-rear-modular-expected.trycloudflare.com/ws

# Dashboard URL (for CORS configuration in your Shopify app)
VITE_DASHBOARD_URL=https://rebound-cart.lovable.app

# Environment
VITE_NODE_ENV=development

# === Production Examples ===
# Uncomment and update these for production deployment

# VITE_SHOPIFY_APP_URL=https://your-shopify-app.com
# VITE_API_KEY=your-production-api-key
# VITE_WS_URL=wss://your-shopify-app.com/ws
# VITE_DASHBOARD_URL=https://your-production-dashboard.com

# === Staging Examples ===
# VITE_SHOPIFY_APP_URL=https://staging-your-shopify-app.com
# VITE_API_KEY=your-staging-api-key
# VITE_WS_URL=wss://staging-your-shopify-app.com/ws
# VITE_DASHBOARD_URL=https://staging-your-dashboard.lovable.dev
