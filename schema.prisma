// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
  role                String?    @default("STORE_OWNER") // "STORE_OWNER", "PLATFORM_ADMIN", "SALES_REP"
}

model SalesRep {
  id                String              @id @default(uuid())
  email             String              @unique
  firstName         String?
  lastName          String?
  role              String              @default("REP") // "ADMIN", "REP"
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
}

model AbandonedCheckout {
  id            String      @id @default(uuid())
  shop          String
  checkoutId    String      @unique
  cartToken     String?
  email         String?
  name          String?
  totalPrice    Decimal
  currency      String
  checkoutUrl   String?
  status        String      @default("ABANDONED") // "ABANDONED", "RECOVERED"
  claimedBy     PlatformUser?   @relation(fields: [claimedById], references: [id])
  claimedById   String?
  claimedAt     DateTime?
  orderId       String?     @unique
  commission    Commission?
  platformFee   Decimal?    @default(0) // Platform fee (e.g., 5%)
  lastContactedAt DateTime?  // Track last rep activity
  communications  Communication[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([shop])
  @@index([claimedById])
}

model Communication {
  id              String            @id @default(uuid())
  checkout        AbandonedCheckout @relation(fields: [checkoutId], references: [id])
  checkoutId      String
  rep             PlatformUser      @relation(fields: [repId], references: [id])
  repId           String
  channel         String            // "WhatsApp", "Email", "Phone", "SMS"
  content         String?           // Message summary
  qcScore         Float?            // 0-100 (AI generated)
  qcFeedback      String?           // AI suggestions
  sentiment       String?           // Positive, Neutral, Negative
  customerRating  Int?              // 1-5 (customer survey)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([checkoutId])
  @@index([repId])
}

model Commission {
  id               String            @id @default(uuid())
  orderId          String            @unique
  orderNumber      String?
  totalAmount      Decimal
  commissionAmount Decimal
  platformFee      Decimal?           @default(0) // Platform fee from this commission
  status           String            @default("PENDING") // "PENDING", "PAID"
  checkout         AbandonedCheckout @relation(fields: [checkoutId], references: [id])
  checkoutId       String            @unique
  rep              PlatformUser      @relation(fields: [repId], references: [id])
  repId            String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model ShopSettings {
  id                    String   @id @default(uuid())
  shop                  String   @unique
  commissionRate        Decimal  @default(10.0) // Percentage
  isMarketplaceEnabled  Boolean  @default(true) // If true, checkouts are visible to marketplace
  recoveryTone          String   @default("FRIENDLY") // "FRIENDLY", "PROFESSIONAL", "URGENT"
  customInstructions     String?  // Instructions for representatives
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model PlatformUser {
  id            String    @id @default(uuid())
  email         String    @unique
  firstName     String?
  lastName      String?
  phone         String?
  role          String    @default("SALES_REP") // "PLATFORM_ADMIN", "SALES_REP"
  status        String    @default("ACTIVE")    // "ACTIVE", "INACTIVE", "SUSPENDED", "PENDING", "REJECTED"
  tier          String?   @default("BRONZE")    // "BRONZE", "SILVER", "GOLD", "PLATINUM"
  commissionRate Decimal?                       // Override tier default rate
  experience    String?                         // Years of sales experience
  skills        String?                         // Skills summary from signup
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  claimedCheckouts AbandonedCheckout[]
  commissions    Commission[]
  communications Communication[]
}

model AssignmentRule {
  id                String    @id @default(uuid())
  name              String
  description       String?
  conditions         Json?     // Store conditions for assignment
  isActive          Boolean   @default(true)
  createdBy         String
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}
